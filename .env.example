# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el .env al repositorio

# Base de datos
MYSQL_DATABASE=pvreza_db
MYSQL_USER=root
MYSQL_PASSWORD=TU_PASSWORD_SEGURA
MYSQL_ROOT_PASSWORD=TU_ROOT_PASSWORD_SEGURA

# PHPMyAdmin
PMA_HOST=db
PMA_USER=root
PMA_PASSWORD=TU_PASSWORD_SEGURA

# Puertos
EXPRESS_PORT=3000
MYSQL_PORT=3306
PHPMYADMIN_PORT=8081

# JWT — genera uno seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_Y_ALEATORIA

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# PHP
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=30
PHP_UPLOAD_MAX_FILESIZE=20M
PHP_POST_MAX_SIZE=20M
